# 生产环境配置示例

# 前端端口
HTTP_PORT=80

# 数据库服务器配置（服务器 B 的 IP）
DB_HOST=106.53.206.106
DB_PORT=3306
DB_USERNAME=user
DB_PASSWORD=password123

# MongoDB 配置
MONGO_URI=mongodb://root:your-mongo-password@106.53.206.106:27017/emohealing_log_db?authSource=admin
AI_MONGO_URI=mongodb://root:your-mongo-password@106.53.206.106:27017/comprehensive_project?authSource=admin
AI_MONGO_DB=comprehensive_project
AI_MONGO_COLLECTION=ai_chat_log

# RabbitMQ 配置
RABBITMQ_USER=admin
RABBITMQ_PASS=your-rabbitmq-password
RABBITMQ_MANAGEMENT_PORT=15672

# JWT 密钥（生产环境必须使用强密钥）
JWT_SECRET=your-very-long-and-random-secret-key-here-at-least-32-characters

# AI API 密钥
DASHSCOPE_API_KEY=sk-6208fc97a97c484fab441c30a0eaa0c1
SILICONFLOW_API_KEY=sk-njxfdshmcwbtjaizlxwmaguxyggqismnzpbvjqgagvlhsbdh
SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
SILICONFLOW_TTS_VOICE=FunAudioLLM/CosyVoice2-0.5B:claire

# 管理员账号（首次部署时启用）
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-this-password-immediately
ADMIN_BOOTSTRAP_FORCE=false

# 前端配置
VITE_ENABLE_PYTHON_PUBLIC_FALLBACK=false

# 调试端口（可选）
GATEWAY_DEBUG_PORT=8080
