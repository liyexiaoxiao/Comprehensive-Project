# Copy this file to .env on the application server.

# Public HTTP port for Nginx/frontend.
HTTP_PORT=80

# Server B private IP or reachable hostname.
DB_HOST=10.0.0.20
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=replace_with_mysql_root_password

# MongoDB on Server B. Keep authSource=admin when using the db compose file.
MONGO_URI=mongodb://root:replace_with_mongo_root_password@10.0.0.20:27017/emohealing_log_db?authSource=admin
AI_MONGO_URI=mongodb://root:replace_with_mongo_root_password@10.0.0.20:27017/comprehensive_project?authSource=admin
AI_MONGO_DB=comprehensive_project
AI_MONGO_COLLECTION=ai_chat_log

# RabbitMQ runs on the application server.
RABBITMQ_USER=admin
RABBITMQ_PASS=replace_with_rabbitmq_password
RABBITMQ_MANAGEMENT_PORT=15672

# JWT secret must be identical for api-gateway, user-service, and meditation-service.
JWT_SECRET=replace_with_a_long_random_secret

# Third-party AI API keys.
DASHSCOPE_API_KEY=replace_with_dashscope_api_key
SILICONFLOW_API_KEY=replace_with_siliconflow_api_key
SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
SILICONFLOW_TTS_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex

# Optional admin bootstrap. Enable only for first deployment or password reset.
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change_me_before_enabling
ADMIN_BOOTSTRAP_FORCE=false

# Optional frontend behavior.
VITE_ENABLE_PYTHON_PUBLIC_FALLBACK=false

# Debug-only local bindings on the application server.
GATEWAY_DEBUG_PORT=8080
