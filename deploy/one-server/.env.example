# Copy this file to .env on the main application server.

HTTP_PORT=80
GATEWAY_DEBUG_PORT=8080

# Existing MySQL on the same host. Docker services reach it through host.docker.internal.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USERNAME=replace_with_mysql_user
DB_PASSWORD=replace_with_mysql_password
USER_DB_NAME=emohealing_user_db
MUSIC_DB_NAME=emohealing_music_db
SOCIAL_DB_NAME=emohealing_social_db
MEDITATION_DB_NAME=emohealing_meditation_db

# RabbitMQ runs in Docker.
RABBITMQ_USER=admin
RABBITMQ_PASS=replace_with_rabbitmq_password
RABBITMQ_MANAGEMENT_PORT=15672

# Must be identical across gateway, user-service, meditation-service, python-backend, and ai-service.
JWT_SECRET=replace_with_a_long_random_secret

# Optional admin bootstrap. Enable only for first deployment or password reset.
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace_with_admin_password
ADMIN_BOOTSTRAP_FORCE=false

# MongoDB runs in Docker and is shared by data-service and ai-service.
MONGO_ROOT_PASSWORD=replace_with_mongo_root_password
DATA_MONGO_DB=emohealing_log_db
AI_MONGO_DB=comprehensive_project
AI_MONGO_COLLECTION=ai_chat_log

# AI providers.
DASHSCOPE_API_KEY=replace_with_dashscope_key
SILICONFLOW_API_KEY=replace_with_siliconflow_key
SILICONFLOW_TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
SILICONFLOW_TTS_VOICE=FunAudioLLM/CosyVoice2-0.5B:alex

# Remote emotion recognition service.
EMOTION_SERVICE_URL=http://replace_with_emotion_server_ip:5003/predict

VITE_ENABLE_PYTHON_PUBLIC_FALLBACK=false
