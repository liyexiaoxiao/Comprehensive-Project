FROM node:20-alpine AS build

WORKDIR /app

ARG VITE_GATEWAY_BASE_URL=/
ARG VITE_PYTHON_BASE_URL=/py-api
ARG VITE_AI_SERVICE_BASE_URL=/ai-api
ARG VITE_ENABLE_PYTHON_PUBLIC_FALLBACK=false

ENV VITE_GATEWAY_BASE_URL=${VITE_GATEWAY_BASE_URL}
ENV VITE_PYTHON_BASE_URL=${VITE_PYTHON_BASE_URL}
ENV VITE_AI_SERVICE_BASE_URL=${VITE_AI_SERVICE_BASE_URL}
ENV VITE_ENABLE_PYTHON_PUBLIC_FALLBACK=${VITE_ENABLE_PYTHON_PUBLIC_FALLBACK}

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
